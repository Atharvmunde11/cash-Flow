{
  "name": "cashflow",
  "version": "1.1.0",
  "main": "electron/main.js",
  "description": "CashFlow - local-first billing and inventory for small businesses",
  "author": "Atharv Munde",
  "repository": {
    "type": "git",
    "url": "https://github.com/Atharvmunde11/cash-Flow.git"
  },
  "homepage": "https://github.com/Atharvmunde11/cash-Flow",
  "license": "Elastic-2.0",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test src/**/*.test.ts",
    "electron": "electron .",
    "electron-dev": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"next dev --webpack\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3 -m .next/standalone",
    "rebuild-sqlite-for-node": "npm rebuild better-sqlite3",
    "prepare-electron": "node electron/prepare-next.js",
    "electron-build:prep": "npm run clean:next && npm run build && npm run prepare-electron && node scripts/generate-icon-ico.js",
    "electron-build": "node scripts/electron-build-win.js",
    "electron-build:x64": "npm run electron-build:prep && node scripts/electron-rebuild-standalone.js x64 && npx electron-builder --win --x64 && node scripts/preserve-update-manifest.js x64 && npm run rebuild-sqlite-for-node",
    "electron-build:arm64": "npm run electron-build:prep && node scripts/electron-rebuild-standalone.js arm64 && npx electron-builder --win --arm64 && node scripts/preserve-update-manifest.js arm64 && npm run rebuild-sqlite-for-node",
    "electron-publish": "node scripts/electron-publish.js",
    "electron-publish:upload": "node scripts/electron-publish.js --upload-only",
    "electron-publish:x64": "node scripts/electron-publish.js",
    "electron-publish:arm64": "node scripts/electron-publish.js"
  },
  "build": {
    "appId": "com.cashflow.app",
    "productName": "CashFlow",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/prisma/**",
      "**/node_modules/.prisma/**",
      "**/node_modules/@prisma/**"
    ],
    "files": [
      "electron/**/*",
      "public/icon.png",
      "public/icon.ico",
      "package.json",
      "prisma/**/*",
      "prisma.config.ts"
    ],
    "afterPack": "./electron/after-pack.js",
    "publish": {
      "provider": "github",
      "owner": "Atharvmunde11",
      "repo": "cash-Flow",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "artifactName": "${productName}-${arch}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CashFlow",
      "runAfterFinish": true,
      "license": "LICENSE",
      "installerLanguages": [
        "en_US"
      ],
      "displayLanguageSelector": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.95.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.9",
    "fast-xml-parser": "^5.9.3",
    "fuse.js": "^7.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.18.0",
    "prisma": "^7.7.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "wait-on": "^9.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "png-to-ico": "^3.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}

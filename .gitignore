# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/dist
/release

# electron desktop (optional — build locally; not published to GitHub)
/electron/
*.exe
*.blockmap

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local sqlite databases
dev.db
dev.db-shm
dev.db-wal
prisma/dev.db
prisma/dev.db-shm
prisma/dev.db-wal
*.db
*.db-shm
*.db-wal

# env files (optional overrides only)
.env
.env.local
.env.production
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
